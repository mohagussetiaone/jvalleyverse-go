      "get": {
        "tags": ["Showcases"],
        "summary": "Get showcase details",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Showcase details" },
          "404": { "description": "Showcase not found" }
        }
      },
      "put": {
        "tags": ["Showcases"],
        "summary": "Update showcase (Owner only)",
