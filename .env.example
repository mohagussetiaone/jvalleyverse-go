# JValleyVerse — Environment Variables

# ── Server ──
PORT=3000
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRY=24h

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=jvalleyverse
DB_SSLMODE=disable

# ── Redis ──
REDIS_HOST=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://jvalleyverse.vercel.app

# ── Admin Default ──
ADMIN_EMAIL=admin@jvalleyverse.com
ADMIN_PASSWORD=Admin@123

# ── MinIO Object Storage ──
MINIO_ENDPOINT=minio.mohagussetiaone.my.id
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=A6u5I5NeX
MINIO_BUCKET=jvalleyverse
MINIO_CDN_URL=https://cdn.mohagussetiaone.my.id
MINIO_USE_SSL=true
